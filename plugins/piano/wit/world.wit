package wk:piano;

/// A small piano: it paints a keyboard into its surface and plays notes through
/// wk's Web Audio host, driven by mouse clicks and the computer keyboard.
/// Combines the wasi-gfx (graphics) and wk:webaudio (sound) interfaces.
world piano {
    import wasi:surface/surface@0.0.1;
    import wasi:graphics-context/graphics-context@0.0.1;
    import wasi:frame-buffer/frame-buffer@0.0.1;
    import wk:webaudio/audio;

    export run: func();
}
