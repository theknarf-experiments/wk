# Created by https://www.toptal.com/developers/gitignore/api/rust,macos
# Edit at https://www.toptal.com/developers/gitignore?templates=rust,macos

### macOS ###
# General
.DS_Store
.AppleDouble
.LSOverride

# Icon must end with two \r
Icon


# Thumbnails
._*

# Files that might appear in the root of a volume
.DocumentRevisions-V100
.fseventsd
.Spotlight-V100
.TemporaryItems
.Trashes
.VolumeIcon.icns
.com.apple.timemachine.donotpresent

# Directories potentially created on remote AFP share
.AppleDB
.AppleDesktop
Network Trash Folder
Temporary Items
.apdisk

### macOS Patch ###
# iCloud generated files
*.icloud

### Rust ###
# Generated by Cargo
# will have compiled files and executables
debug/
target/


# These are backup files generated by rustfmt
**/*.rs.bk

# MSVC Windows builds of rustc generate these, which store debugging information
*.pdb

# End of https://www.toptal.com/developers/gitignore/api/rust,macos/target

# Generated by wit-bindgen / cargo-component (regenerated on every build)
plugins/*/src/bindings.rs

# Shared terminal shim: wit-bindgen output for wk:tty/control + cached adapter,
# regenerated by each C terminal plugin's build (only wit/ + the shim C is
# tracked).
plugins/tty-compat/gen/

# kilo build artifacts
plugins/kilo/kilo.wasm
plugins/kilo/kilo.core.wasm

# lua build artifacts (source fetched by build.sh, component built from it)
plugins/lua/lua-5.4.7/
plugins/lua/lua.wasm
plugins/lua/lua.core.wasm

# sqlite build artifacts (amalgamation fetched by build.sh, component built from it)
plugins/sqlite/sqlite-amalgamation-*/
plugins/sqlite/sqlite3.wasm
plugins/sqlite/sqlite3.core.wasm

# vim build artifacts (source fetched + auto/config generated by build.sh,
# objects/libs/adapter derived from it; only compat/ sources are tracked)
plugins/vim/vim-src/
plugins/vim/vim.wasm
plugins/vim/vim.core.wasm
plugins/vim/wkobj/
plugins/vim/compat/*.o
plugins/vim/compat/libwktcap.a
plugins/vim/compat/wasi_snapshot_preview1.command.wasm

# fetch (networked C client) build artifact
plugins/fetch/fetch.wasm

# stray literal-tilde dir from tools that mis-expand $HOME
/~/

# netserve (TCP server example) build artifact
plugins/netserve/netserve.wasm

# udpecho (UDP echo example) build artifact
plugins/udpecho/udpecho.wasm

# echo6 (IPv6 echo example) build artifact
plugins/echo6/echo6.wasm

# HostMappedFile artifacts: `add_host_mapped_file` currently creates its backing
# file (`host<n>`) relative to the process cwd, so they land at the repo root
# when wk runs from here. Ignore them until that's fixed to resolve against the
# workspace file's directory.
/host[0-9]*
