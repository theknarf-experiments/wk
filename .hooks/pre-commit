#!/usr/bin/env bash
set -euo pipefail

# Forbid silencing dead-code warnings; prune the dead code instead. Uses
# `git grep` so it covers all tracked Rust (host + plugin crates) while skipping
# untracked/generated files (e.g. wit-bindgen's bindings.rs).
if matches=$(git grep -nE 'allow\([^)]*dead_code' -- '*.rs'); then
    echo "error: allow(dead_code) is not permitted -- prune the dead code instead:" >&2
    echo "$matches" >&2
    exit 1
fi

cargo fmt --all -- --check

# clippy compiles like `cargo check` and adds lints; `-D warnings` blocks the
# commit on any rustc or clippy warning. `--workspace` lints every member crate
# (wk, wk-server, wk-protocol), not just the root binary.
cargo clippy --workspace --all-targets -- -D warnings

# `--workspace` runs every member crate's tests (the backend tests live in
# wk-server); `--no-tests=pass` so an empty suite doesn't block the commit.
cargo nextest run --workspace --no-tests=pass
