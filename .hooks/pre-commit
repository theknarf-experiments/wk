#!/usr/bin/env bash
set -euo pipefail

# Forbid silencing dead-code warnings; prune the dead code instead.
if matches=$(grep -rnE 'allow\([^)]*dead_code' src); then
    echo "error: allow(dead_code) is not permitted -- prune the dead code instead:" >&2
    echo "$matches" >&2
    exit 1
fi

cargo fmt --all -- --check

# RUSTFLAGS="-D warnings" treats warnings as errors so a commit is blocked
# on any warning.
RUSTFLAGS="-D warnings" cargo check

# --no-tests=pass so an empty test suite doesn't block the commit.
cargo nextest run --no-tests=pass
